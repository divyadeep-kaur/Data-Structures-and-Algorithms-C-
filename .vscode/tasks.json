{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "\"${file}\"",
                "-o",
                "\"${fileDirname}/${fileBasenameNoExtension}\"",
                "&&",
                "\"${fileDirname}/${fileBasenameNoExtension}\""
            ],
            "options": {
                "shell": {
                    "executable": "/bin/zsh",
                    "args": ["-c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": []
        }
    ]
}